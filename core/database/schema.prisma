// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["clients", "workers"]
}

enum VideoStatus {
  none
  demo_scheduled
  demo_started
  demo_finished
  final_progress
  final

  @@schema("clients")
}

model Company {
  id               String            @id @default(uuid())
  name             String
  websiteUrl       String            @map("website_url")
  employees        Int               @default(0)
  industry         String
  campaignId       String            @map("campaign_id")
  primaryColor     String            @default("") @map("primary_color")
  secondaryColor   String            @default("") @map("secondary_color")
  fontFamily       String            @default("") @map("font_family")
  logoUrl          String            @default("") @map("logo_url")
  valueProp        String            @default("") @map("value_prop")
  features         Json              @default("[]") @db.JsonB
  targetAudience   String            @default("") @map("target_audience")
  voiceTone        String            @default("") @map("voice_tone")
  preferredLanguage String           @default("a") @map("preferred_language")
  videoStatus      VideoStatus       @default(none) @map("video_status")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  employeeContacts EmployeeContact[]
  demoVideos       DemoVideo[]
  finalVideos      FinalVideo[]

  @@map("companies")
  @@schema("clients")
}

model DemoVideo {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  videoLink    String    @map("video_link")
  views        Int       @default(0)
  lastViewedAt DateTime? @map("last_viewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("demo_videos")
  @@schema("clients")
}

model FinalVideo {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  videoLink String   @map("video_link")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("final_videos")
  @@schema("clients")
}

model EmployeeContact {
  id               String             @id @default(uuid())
  companyId        String             @map("company_id")
  firstName        String             @map("first_name")
  lastName         String             @map("last_name")
  jobTitle         String             @map("job_title")
  email            String?
  avatarUrl        String             @map("avatar_url")
  linkedinUrl      String             @map("linkedin_url")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  emailEnrichTasks EmailEnrichTask[]

  @@map("employees")
  @@schema("clients")
}

// ============================================================================
// WORKERS SCHEMA
// ============================================================================

enum EmailEnrichTaskStatus {
  pending
  processing
  completed
  failed

  @@schema("workers")
}

model EmailEnrichTask {
  id           String                @id @default(uuid())
  domain       String                @map("domain")
  dnsZone      String                @map("dns_zone")
  executedTime DateTime?             @map("executed_time")
  employeeId   String                @map("employee_id")
  status       EmailEnrichTaskStatus @default(pending)
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  employee     EmployeeContact       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([dnsZone, createdAt])
  @@map("email_enrich_tasks")
  @@schema("workers")
}